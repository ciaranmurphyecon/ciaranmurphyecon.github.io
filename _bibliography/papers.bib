@unpublished{murphy2026housing,
  bibtex_show   = {true},
  title         = {Building Success: The Effect of On-Campus Housing Expansions on Student Outcomes},
  author        = {Murphy, Ciarán},
  year          = {2026},
  abstract      = {Housing shortages are increasingly cited as barriers to degree completion. Using a 17-year panel of 1,256 U.S. colleges, I estimate the effect of dormitory expansions on retention and graduation via within-college differencing models, confirmed by stacked difference-in-differences. Large expansions do not affect first-year retention but raise four-year graduation by 1--2.25 percentage points; effects grow with expansion size and cohort exposure and reflect higher total completion rather than re-timing. Mechanism analyses find no rent-market spillovers, pointing to campus housing access as the primary channel. Expanding on-campus capacity is a tractable, institution-controlled policy to raise graduation rates.},
  pdf           = {building_success_jmp.pdf}
}

@unpublished{crotty2025gendergap,
  bibtex_show = {true},
  title       = {The Origins of the STEM Gender Gap: Evidence from an Analysis of Secondary School Subject Selection},
  author      = {Crotty, Dáire and Murphy, Ciarán},
  year        = {2025},
  abstract    = {Secondary school subject choices are a key gateway to STEM (Science, Technology, Engineering and Maths), yet their determinants remain underexplored. Using the Growing Up in Ireland study, this paper employs regression and decomposition analysis to examine STEM participation. We document substantial gender gaps in practical-based STEM subjects, but not in science or maths. Lower secondary choices play a central role in shaping later trajectories and explain most upper secondary gender gaps. However, lower-secondary gaps are not explained by conventional mechanisms such as early characteristics, comparative advantage, schools, or peers. Results are robust to alternative specifications, including machine learning methods.},
  pdf         = {origins_stem_gender_gap.pdf}
}

@unpublished{murphy2026lockdowns,
  bibtex_show = {true},
  title       = {Lockdowns and Conspiracy Theories: Evidence from European Policy Variation},
  author      = {Murphy, Ciarán},
  year        = {2026},
  abstract    = {When European governments locked down their populations during Covid-19, they inadvertently increased demand for conspiracy theories. This paper provides demand-side evidence on what drives online conspiracy narratives, exploiting differential variation in lockdown stringency across 31 European countries. Stricter lockdowns significantly raised conspiracy search interest during 2020--2021. Evidence points to social isolation as the operative mechanism: the sustained level of restriction predicts conspiracy search while week-on-week changes do not, and restrictions that physically confine people drive the result while mask mandates do not. The findings suggest that social capital disruption is a distinct driver of conspiratorial information-seeking.},
  pdf         = {lockdowns_conspiracy_theories.pdf}
}

@misc{murphy2025football,
  title       = {The Other Side of the Game: Coaching Allocation and Player Effort in Football Academies},
  author      = {Murphy, Ciarán},
  year        = {2025},
  abstract    = {Professional soccer academies admit cohorts of players annually with the aim of maximising the playing ability of the select few who are ultimately offered professional contracts. The academies allocate coaching between players with this aim, while players choose the level of effort to exert in academy training. For the unsuccessful players, this effort is sunk and can come at the cost of fully focusing on an education or a conventional career. This paper shows that the coaching allocation which maximises the expected ability of the successful players also maximises the expected wasted effort of the unsuccessful players, demonstrating an externality which exists within this system.},
  note        = {Work in progress -- draft available soon}
}

